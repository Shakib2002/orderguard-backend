# ============================================================
# OrderGuard Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3000                     # HTTP port to listen on
APP_VERSION=1.0.0             # Displayed in /health endpoint
BASE_URL=http://localhost:3000 # Public base URL (no trailing slash)

# ── Database (Supabase / PostgreSQL via Prisma) ───────────────
# Get this from: Supabase Dashboard → Settings → Database → Connection string
# Use the "URI" format with connection pooling (port 6543) for production
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres?schema=public"

# For Supabase connection pooling (recommended for Render free tier):
# DATABASE_URL="postgresql://postgres.[YOUR-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ── JWT Authentication ────────────────────────────────────────
# Generate secure secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_super_secret_access_token_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m    # Access token lifetime (15 minutes)
JWT_REFRESH_EXPIRES_IN=30d   # Refresh token lifetime (30 days)

# ── Security ─────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX=100            # Max requests per window per IP

# Encryption key for sensitive fields (e.g., Gmail app passwords)
# Must be exactly 32 characters for AES-256
ENCRYPTION_KEY=your_32_char_encryption_key_here!!

# ── Twilio (for automated call verification) ─────────────────
# Sign up at: https://www.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # Twilio phone number

# ── Gmail / IMAP (for email-based order parsing) ─────────────
# Use Gmail App Passwords (not your main password)
# Enable: Google Account → Security → 2FA → App passwords
GMAIL_CHECK_INTERVAL_MS=300000    # How often to poll Gmail (5 minutes)

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info                # error | warn | info | http | debug
LOG_DIR=logs                  # Directory for log files

# ── Render.com Specific ───────────────────────────────────────
# Render automatically sets PORT; do not override it in production
# Set all other variables above in Render's Environment settings panel
