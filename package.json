{
  "name": "orderguard-backend",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS backend for Bangladesh e-commerce fake order detection",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "npx prisma migrate deploy",
    "migrate:dev": "npx prisma migrate dev",
    "generate": "npx prisma generate",
    "studio": "npx prisma studio",
    "seed": "node prisma/seed.js",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix"
  },
  "keywords": [
    "orderguard",
    "fake-order",
    "ecommerce",
    "bangladesh",
    "saas",
    "multi-tenant"
  ],
  "author": "OrderGuard Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "firebase-admin": "^13.8.0",
    "helmet": "^7.1.0",
    "imap": "^0.8.19",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.8",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "twilio": "^6.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.3",
    "pg": "^8.20.0",
    "prisma": "^5.14.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
